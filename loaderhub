--  DESPEGUE
--  1. Esconder todo el texto del frame inmediatamente
--  2. Sacar el cohete al gui
--  3. Moverlo al centro X de pantalla (misma Y)
--  4. Rotar -90 para apuntar arriba
--  5. Subir hasta salir de pantalla
-- ══════════════════════════════

-- Esconder todo antes del shrink (texto, barra y estrellas)
title.Visible = false
pct.Visible   = false
barBg.Visible = false
for _, child in ipairs(frame:GetChildren()) do
    if child:IsA("Frame") and child ~= barBg and child ~= rocketFrame then
        child.Visible = false
    end
end

frame.ClipsDescendants = false

local camera   = workspace.CurrentCamera
local screenSz = camera.ViewportSize

local absPos = rocketFrame.AbsolutePosition
local absSz  = rocketFrame.AbsoluteSize

-- Llevar cohete al gui con su posición absoluta actual
rocketFrame.Parent      = gui
rocketFrame.ZIndex      = 10
rocketFrame.AnchorPoint = Vector2.new(0.5, 0.5)
rocketFrame.Position    = UDim2.new(
    (absPos.X + absSz.X * 0.5) / screenSz.X, 0,
    (absPos.Y + absSz.Y * 0.5) / screenSz.Y, 0
)

-- Shrink del frame
TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
    Size     = UDim2.new(0, 0, 0, 0),
    Position = UDim2.new(0.5, 0, 0.5, 0),
}):Play()

fire.Visible = true
sound:Play()

-- Paso 1: mover al centro X de la pantalla y rotar hacia arriba
local currentY = rocketFrame.Position.Y.Scale
TweenService:Create(rocketFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
    Position = UDim2.new(0.5, 0, currentY, 0),
    Rotation = -90,
}):Play()
task.wait(0.4)

-- Paso 2: subir recto hasta salir por arriba
TweenService:Create(rocketFrame, TweenInfo.new(1.1, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
    Position = UDim2.new(0.5, 0, -0.2, 0)
}):Play()

task.wait(1.3)
frame:Destroy()
rocketFrame:Destroy()


-- METEORS — diagonal streaks across the background
local meteorContainer = Instance.new("Frame")
meteorContainer.Size = UDim2.new(1,0,1,0)
meteorContainer.Position = UDim2.new(0,0,0,0)
meteorContainer.BackgroundTransparency = 1
meteorContainer.ClipsDescendants = true
meteorContainer.ZIndex = 1
meteorContainer.Parent = main

local FRAME_W = 600
local FRAME_H = 350

local function spawnMeteor()
    local tailLen = math.random(25, 50)
    local thickness = math.random(1, 2)
    local speed = math.random(10, 18) / 10

    local side = math.random(1, 4)
    local startX, startY, endX, endY

    if side == 1 then
        -- From top edge, moving downward
        startX = math.random(10, 90) / 100
        startY = math.random(5, 12) / 100
        endX = math.random(10, 90) / 100
        endY = math.random(65, 90) / 100
    elseif side == 2 then
        -- From right edge, moving left
        startX = math.random(82, 95) / 100
        startY = math.random(10, 90) / 100
        endX = math.random(5, 25) / 100
        endY = math.random(10, 90) / 100
    elseif side == 3 then
        -- From bottom edge, moving upward
        startX = math.random(10, 90) / 100
        startY = math.random(85, 95) / 100
        endX = math.random(10, 90) / 100
        endY = math.random(5, 30) / 100
    else
        -- From left edge, moving right
        startX = math.random(5, 18) / 100
        startY = math.random(10, 90) / 100
        endX = math.random(70, 95) / 100
        endY = math.random(10, 90) / 100
    end

    -- Compute visual angle accounting for aspect ratio
    local dx = (endX - startX) * FRAME_W
    local dy = (endY - startY) * FRAME_H
    local rot = math.deg(math.atan2(dy, dx))

    local meteor = Instance.new("Frame")
    meteor.Size = UDim2.new(0, tailLen, 0, thickness)
    meteor.Position = UDim2.new(startX, 0, startY, 0)
    meteor.AnchorPoint = Vector2.new(0.5, 0.5)
    meteor.Rotation = rot
    meteor.BackgroundColor3 = WHITE
    meteor.BackgroundTransparency = 0.2
    meteor.BorderSizePixel = 0
    meteor.ZIndex = 1
    meteor.ClipsDescendants = true
    meteor.Parent = meteorContainer
    Instance.new("UICorner", meteor).CornerRadius = UDim.new(1, 0)

    local grad = Instance.new("UIGradient")
    grad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 1),
        NumberSequenceKeypoint.new(0.7, 0.4),
        NumberSequenceKeypoint.new(1, 0),
    })
    grad.Parent = meteor

    local head = Instance.new("Frame")
    head.Size = UDim2.new(0, 3, 0, 3)
    head.AnchorPoint = Vector2.new(0.5, 0.5)
    head.Position = UDim2.new(1, -2, 0.5, 0)
    head.BackgroundColor3 = Color3.fromRGB(200, 220, 255)
    head.BackgroundTransparency = 0
    head.BorderSizePixel = 0
    head.ZIndex = 1
    head.Parent = meteor
    Instance.new("UICorner", head).CornerRadius = UDim.new(1, 0)

    TweenService:Create(meteor, TweenInfo.new(speed, Enum.EasingStyle.Linear), {
        Position = UDim2.new(endX, 0, endY, 0)
    }):Play()

    -- Blink effect: rapidly pulse opacity during flight
    task.spawn(function()
        local startTime = os.clock()
        while meteor.Parent and (os.clock() - startTime) < speed * 0.7 do
            local blinkSpeed = 0.1 + math.random() * 0.15
            TweenService:Create(meteor, TweenInfo.new(blinkSpeed), {
                BackgroundTransparency = 0.8
            }):Play()
            TweenService:Create(head, TweenInfo.new(blinkSpeed), {
                BackgroundTransparency = 0.7
            }):Play()
            task.wait(blinkSpeed)

            TweenService:Create(meteor, TweenInfo.new(blinkSpeed), {
                BackgroundTransparency = 0.1
            }):Play()
            TweenService:Create(head, TweenInfo.new(blinkSpeed), {
                BackgroundTransparency = 0
            }):Play()
            task.wait(blinkSpeed)
        end
    end)

    task.delay(speed * 0.75, function()
        TweenService:Create(meteor, TweenInfo.new(speed * 0.25), {
            BackgroundTransparency = 1
        }):Play()
        TweenService:Create(head, TweenInfo.new(speed * 0.25), {
            BackgroundTransparency = 1
        }):Play()
    end)

    task.delay(speed + 0.1, function()
        meteor:Destroy()
    end)
end

task.spawn(function()
    while meteorContainer.Parent do
        spawnMeteor()
        task.wait(math.random(8,20) / 10)
    end
end)


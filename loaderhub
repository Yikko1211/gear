local function setProgress(p)
    pct.Text = p .. "%"
    TweenService:Create(bar, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(p / 100, 0, 1, 0)

-- TOGGLE (gray = off, white = on)
local GRAY = Color3.fromRGB(80, 80, 80)

local function createToggle(parent, text, y, callback)
    local holder = Instance.new("Frame")
    holder.Size = UDim2.new(1,-20,0,40)
    holder.Position = UDim2.new(0,10,0,y)
    holder.BackgroundTransparency = 1
    holder.Parent = parent or content

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.7,0,1,0)
    label.Text = text
    label.TextColor3 = WHITE
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.Parent = holder
    label.ZIndex = 3

    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0,40,0,20)
    toggle.Position = UDim2.new(1,-50,0.5,-10)
    toggle.BackgroundColor3 = GRAY
    toggle.Text = ""
    toggle.Parent = holder
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(1,0)
    toggle.ZIndex = 3

    local on = false

    toggle.MouseButton1Click:Connect(function()
        on = not on

        TweenService:Create(toggle, TweenInfo.new(0.2), {
            BackgroundColor3 = on and WHITE or GRAY
        }):Play()

        if callback then
            callback(on)
        end
    end)
end

-- SLIDER (gray track, white knob)
local function createSlider(parent, text, y, minVal, maxVal, default, callback)
    local holder = Instance.new("Frame")
    holder.Size = UDim2.new(1,-20,0,40)
    holder.Position = UDim2.new(0,10,0,y)
    holder.BackgroundTransparency = 1
    holder.Parent = parent or content

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.45,0,1,0)
    label.Text = text
    label.TextColor3 = WHITE
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = holder
    label.ZIndex = 3

    local track = Instance.new("Frame")
    track.Size = UDim2.new(0.5,0,0,6)
    track.Position = UDim2.new(0.45,0,0.5,-3)
    track.BackgroundColor3 = GRAY
    track.BorderSizePixel = 0
    track.Parent = holder
    track.ZIndex = 3
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)

    local knob = Instance.new("TextButton")
    knob.Size = UDim2.new(0,14,0,14)
    knob.AnchorPoint = Vector2.new(0.5,0.5)
    knob.BackgroundColor3 = WHITE
    knob.Text = ""
    knob.BorderSizePixel = 0
    knob.Parent = track
    knob.ZIndex = 4
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

    local valLabel = Instance.new("TextLabel")
    valLabel.Size = UDim2.new(0,30,0,14)
    valLabel.Position = UDim2.new(1,5,0.5,-7)
    valLabel.BackgroundTransparency = 1
    valLabel.TextColor3 = WHITE
    valLabel.Font = Enum.Font.Gotham
    valLabel.TextSize = 11
    valLabel.TextXAlignment = Enum.TextXAlignment.Left
    valLabel.Parent = track
    valLabel.ZIndex = 3

    local function setVal(pct)
        pct = math.clamp(pct, 0, 1)
        knob.Position = UDim2.new(pct, 0, 0.5, 0)
        local val = math.floor(minVal + (maxVal - minVal) * pct)
        valLabel.Text = tostring(val)
        if callback then callback(val) end
    end

    local defaultPct = (default - minVal) / (maxVal - minVal)
    setVal(defaultPct)

    local sliding = false

    knob.MouseButton1Down:Connect(function()
        sliding = true
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
            local trackAbsPos = track.AbsolutePosition.X
            local trackAbsSize = track.AbsoluteSize.X
            local mouseX = input.Position.X
            local pct = (mouseX - trackAbsPos) / trackAbsSize
            setVal(pct)
        end
    end)
end

